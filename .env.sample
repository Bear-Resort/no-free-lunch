# Copy to `.env.local` and fill in real values. Never commit `.env` / `.env.local`.
#
# After `npx convex dev` once, Convex usually writes CONVEX_DEPLOYMENT + VITE_CONVEX_URL
# into `.env.local` for you.

# --- Vite / browser (required for online mode) ---
# From Convex dashboard → Deployment Settings → URL
VITE_CONVEX_URL=https://your-deployment-name.convex.cloud

# --- Convex CLI (written by `npx convex dev`) ---
CONVEX_DEPLOYMENT=dev:your-deployment-name

# --- GitHub Actions (DO NOT put in .env.local for day-to-day local work) ---
# Repo → Settings → Secrets and variables → Actions → New repository secret
#   Name:  CONVEX_DEPLOY_KEY
#   Value: Production Deploy Key from
#          Convex Dashboard → Production deployment → Settings → Deploy Keys
# CONVEX_DEPLOY_KEY=prod:your-deployment|xxxxxxxx

# --- Optional: Convex dashboard environment variables ---
# Set with: npx convex env set NAME value
# (Not read by Vite — these live on the Convex deployment.)
#
# Example placeholders only:
# OPENAI_API_KEY=sk-sample-not-a-real-key
# OPENAI_NARRATOR_MODEL=gpt-5.6-luna
